# Minimal Antfly — no AVX2 (no GOEXPERIMENT=simd), no local ML (external embeddings only)
# For CPUs without AVX2 and when using OpenAI/Ollama/etc for embeddings.
#
# Build: docker build -f Dockerfile.antfly-minimal -t formatforge-antfly:minimal .
# Run:   docker run -p 8080:8080 formatforge-antfly:minimal swarm --termite=false

FROM golang:1.26-alpine AS builder

WORKDIR /app

COPY antfly-src/go.mod antfly-src/go.sum ./
COPY antfly-src/termite ./termite
COPY antfly-src/cmd/antfly ./cmd/antfly
COPY antfly-src/pkg ./pkg

RUN go mod download

COPY antfly-src/ .

ARG TARGETOS=linux
ARG TARGETARCH=amd64

# No GOEXPERIMENT=simd — uses scalar fallbacks, runs on AVX-only CPUs
# CGO_ENABLED=0 — static binary, no ONNX/XLA
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} \
    go build -a -installsuffix cgo -o antfly ./cmd/antfly

FROM alpine:latest

WORKDIR /

COPY --from=builder /app/antfly /antfly

# swarm without termite — use external embedder (OpenAI, Ollama, etc.)
ENTRYPOINT ["/antfly"]
CMD ["swarm", "--termite=false", "--metadata-api=http://0.0.0.0:8080"]
