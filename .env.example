# PocketBase
# When using docker-compose.nginx.yml, PHP auto-connects to pocketbase:8090 (no need to set)
POCKETBASE_URL=http://127.0.0.1:8090
# Frontend fetches from this URL. Default: site_url + /pb (requires nginx proxy). For start.sh without nginx: POCKETBASE_PUBLIC_URL=http://127.0.0.1:8090
# POCKETBASE_PUBLIC_URL=
APP_PORT=8000
ADMIN_EMAIL=
ADMIN_PASSWORD=
MIGRATE_SECRET=

# Garage S3
GARAGE_ENDPOINT=http://127.0.0.1:3900
GARAGE_ACCESS_KEY=
GARAGE_SECRET_KEY=
GARAGE_BUCKET=formatforge
GARAGE_REGION=garage

# Replicate
REPLICATE_API_TOKEN=

# fal.ai (alternative to Replicate for video generation)
# FAL_KEY=
# VIDEO_PROVIDER=replicate|fal  # default: replicate if token set, else fal if FAL_KEY set
# FAL_VIDEO_MODEL=fal-ai/kling-video/v2.5-turbo/pro/text-to-video

# Instagram / Facebook App (requires business_management permission in App Dashboard)
FB_APP_ID=
FB_APP_SECRET=
INSTAGRAM_REDIRECT_URI=   # e.g. https://formatforgeplus.com/instagram/callback
META_WEBHOOK_VERIFY_TOKEN=   # For webhooks: same value as "Verify Token" in Meta App Dashboard

# Antfly (self-hosted)
ANTFLY_URL=http://127.0.0.1:8080
ANTFLY_API_KEY=

# Source link fetchers (optional — for "Fetch" on queued links)
# GALLERY_DL_PATH=gallery-dl   # Images from Instagram, Imgur, DeviantArt, etc.
# YT_DLP_PATH=yt-dlp           # Video/audio from YouTube, etc.

# App
APP_URL=http://localhost
# Production: APP_URL=https://formatforgeplus.com
APP_VERSION=v1.0.9
WINNING_TEMPLATE_VIEW_SHARE_RATIO=0.05
FFMPEG_PATH=/usr/bin/ffmpeg

# Allow signup on login page (set to 1 to always show create-account form)
# When unset, signup is only shown when request is from internal IP (100.x, 10.x, 192.168.x, 172.16-31.x)
# ALLOW_SIGNUP=1

# Autonomous pipeline triggers (pi coding agent)
# When content is rejected or novel, a trigger is written and setup_pipeline_from_trigger() runs
# PI_TRIGGER_DIR=/path/to/.pi/triggers
# NOVEL_DISTANCE_THRESHOLD=0.35  # Cosine distance above this = novel content

# Embeddings (for novelty detection; pick one)
# OPENROUTER_API_KEY=   # Preferred: embeddings + pi use same key
# EMBED_MODEL=openai/text-embedding-3-small  # OpenRouter embedding model
# OPENAI_API_KEY=   # Alternative: OpenAI direct
# EMBED_URL=http://localhost:11434  # Ollama /api/embed (nomic-embed-text)

# Pi coding agent (for pipeline creation/editing)
# OPENROUTER_API_KEY=   # Same key for embeddings + pi
# PI_MODEL=openai/gpt-4o-mini  # Model pi uses when running
