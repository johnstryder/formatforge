# PocketBase (PHP must reach this URL — same host: 127.0.0.1:8090)
# When set, overrides repo .pb-port.
# Compatible with stock PocketBase or the vectorbase (libSQL) fork: same /api/collections/* and /api/health.
# Optional vectorbase-only routes: /api/vector-search/* (see pb_vector_search_* in index.php).
POCKETBASE_URL=http://127.0.0.1:8090
# Frontend fetches from this URL. Default: site_url (nginx proxies /api/ and /_/ to PocketBase). For start.sh without nginx: POCKETBASE_PUBLIC_URL=http://127.0.0.1:8090
# POCKETBASE_PUBLIC_URL=
# Optional: internal id of the content_items collection (Admin → Collections → content_items). Avoids a superuser lookup; fixes /api/files/… URLs when list responses omit collectionId. The PHP pb_proxy also injects ff_display_media_url (PocketBase file URL first) on each content_items row.
# POCKETBASE_CONTENT_ITEMS_COLLECTION_ID=pbc_3823730926
APP_PORT=8000
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Used for superuser API (e.g. recording pipeline reject feedback into pipelines.metadata). Same account as PocketBase admin.
MIGRATE_SECRET=

# Garage S3 — PHP uses GARAGE_ENDPOINT for SigV4 PUT; browsers / Instagram need a public URL
GARAGE_ENDPOINT=http://127.0.0.1:3900
# Public web base (no trailing path). Never use http://127.0.0.1 — browsers cannot load that for users.
# If APP_URL is https://…, the app upgrades http:// Garage URLs to https:// for images (mixed content). Set GARAGE_PUBLIC_SCHEME=http only if your Garage truly has no TLS.
# Option A: full base URL (virtual-hosted or path-style gateway)
# GARAGE_PUBLIC_URL=https://my-bucket.web.100.107.100.17.sslip.io
# Option B: only the Garage "root domain" — app builds https://GARAGE_BUCKET.web.ROOT/ (override scheme with GARAGE_PUBLIC_SCHEME=http if needed)
# GARAGE_PUBLIC_ROOT_DOMAIN=100.107.100.17.sslip.io
# GARAGE_PUBLIC_SCHEME=https
GARAGE_ACCESS_KEY=
GARAGE_SECRET_KEY=
# Must match the first label of the virtual host (e.g. my-bucket.web.*) if you use Garage virtual-hosted URLs
GARAGE_BUCKET=formatforge
GARAGE_REGION=garage

# Replicate
REPLICATE_API_TOKEN=

# fal.ai (alternative to Replicate for video generation)
# FAL_KEY=
# VIDEO_PROVIDER=replicate|fal  # default: replicate if token set, else fal if FAL_KEY set
# FAL_VIDEO_MODEL=fal-ai/kling-video/v2.5-turbo/pro/text-to-video

# Instagram / Facebook App (requires business_management permission in App Dashboard)
FB_APP_ID=
FB_APP_SECRET=
INSTAGRAM_REDIRECT_URI=   # e.g. https://formatforgeplus.com/instagram/callback
META_WEBHOOK_VERIFY_TOKEN=   # For webhooks: same value as "Verify Token" in Meta App Dashboard

# Source link fetchers (Curate → Fetch) — install gallery-dl + yt-dlp on the host (pip); set paths if not on PATH
# GALLERY_DL_PATH=gallery-dl
# YT_DLP_PATH=yt-dlp
# e.g. GALLERY_DL_PATH=/home/you/.local/bin/gallery-dl
# Instagram needs Netscape cookies.txt — see storage/cookies/README.md
# If unset, uses storage/cookies/instagram_cookies.txt or storage/cookies/cookies.txt (first match).
# GALLERY_DL_COOKIES=/var/www/html/storage/cookies/cookies.txt
# YT_DLP_COOKIES=   # optional; defaults to same file as gallery cookies

# App
APP_URL=http://localhost
# Production: APP_URL=https://formatforgeplus.com
APP_VERSION=v1.1.156
WINNING_TEMPLATE_VIEW_SHARE_RATIO=0.05
FFMPEG_PATH=/usr/bin/ffmpeg

# Allow signup on login page (set to 1 to always show create-account form)
# When unset, signup is only shown when request is from internal IP (100.x, 10.x, 192.168.x, 172.16-31.x)
# ALLOW_SIGNUP=1

# Autonomous pipeline triggers — PHP spawns Cursor (web POST: Curate → Fetch, or Reject)
# When content is novel on fetch or reject streak hits, a trigger is written under triggers/, pipeline dir + prompt are prepared, then exec+nohup runs cursor-agent-run
# PHP-FPM: PHP_BINARY is often php-fpm; FormatForge resolves /usr/bin/php (or set explicitly):
# PHP_CLI_BINARY=/usr/bin/php
# Default runtime tree: `.cursor-pipeline/`; if PHP-FPM cannot write there, the app uses `storage/cursor-pipeline/` automatically (same repo; still under agent --workspace).
# CURSOR_PIPELINE_RUNTIME_DIR=storage/cursor-pipeline   # optional: force base dir (relative to app root or absolute under app root)
# CURSOR_PIPELINE_TRIGGER_DIR=/path/to/custom/triggers   # default: <runtime>/triggers (legacy: PI_TRIGGER_DIR)
# NOVEL_DISTANCE_THRESHOLD=0.35  # Distance threshold for novelty checks (if enabled in app logic)
# TARGET_POSTS_PER_DAY=60        # Included in Cursor agent JSON (operating_context) vs published_count_last_24h; set 0 to omit cadence fields
# Pipeline cron — auto-generate when publish cadence lags (skips pipelines busy with recent Cursor agent runs)
# Crontab example: 0 * * * * cd /var/www/formatforge && /usr/bin/php index.php pipeline-cron-tick >>/var/log/formatforge-pipeline-cron.log 2>&1
# (or: sudo ./scripts/install-formatforge-pipeline-cron.sh — same hourly schedule)
# Manual one-shot (ignores PIPELINE_CRON_ENABLED + cadence + auto-post saturation): php index.php pipeline-cron-tick --force
# PIPELINE_CRON_ENABLED=1
# PIPELINE_CRON_CURSOR_AGENT_BUSY_MAX_AGE_SEC=3600   # queued/running agent state older than this does not block cron (0 = never expire, legacy block-forever)
# PIPELINE_CRON_MAX_PER_TICK=2
# PIPELINE_CRON_MAX_QUEUE_PER_PIPELINE=2
# PIPELINE_CRON_PIPELINE_IDS=   # optional comma-separated pipeline record ids; omit = all eligible (active + prompt_template)
# PIPELINE_CRON_ACCOUNT_ID=     # optional Instagram account id; default = first active account
# Auto-post queue (requires PocketBase migration `scheduled_publish_at` on content_items — restart PB after adding)
# Crontab example: * * * * * cd /var/www/formatforge && /usr/bin/php index.php auto-post-tick >>/var/log/formatforge-auto-post.log 2>&1
# AUTO_POST_ENABLED=1
# AUTO_POST_TOTAL_PER_DAY=30
# AUTO_POST_SATURATION_DAYS=7
# AUTO_POST_IMPRESSION_WEIGHTS=1   # 0 = equal thirds; 1 = weight image/video/carousel by published content_metrics.impressions per kind
# AUTO_POST_MAX_PUBLISH_PER_TICK=15
# AUTO_POST_DEFAULT_ACCOUNT_ID=   # optional: when approved rows lack instagram_account_id
# AUTO_POST_PIPELINE_CRON_SATURATION=1   # when AUTO_POST_ENABLED=1: pipeline-cron prefers pipelines for the least-saturated kind (image → video → carousel)
# PIPELINE_REJECT_STREAK=1       # Consecutive rejects for same metadata.pipeline_id → Cursor edits pipeline dir (Go, PB row, etc.; 0 = disable)
# CURSOR_AGENT_ON_PIPELINE_GENERATION_FAILURE=1   # When pipeline binary fails to spawn or PHP blocks pipeline complete-generate, queue Cursor to fix the pipeline (0 = off)
# CURSOR_AGENT_ON_VERIFY_PIPELINE_FAILURE=0      # Set 1 to also queue Cursor when verify-pipeline-generation CLI ends in status=failed
# PIPELINE_AGENT_MEDIA_MAX_BYTES=104857600      # Per-file cap when copying backing/generated media into pipelines/.../agent_media/ for the Cursor agent (default 100 MiB)
# Cursor agent FIFO: if a new trigger fires while that pipeline’s agent is queued/running, the trigger is stored and run after the current run finishes (.cursor-pipeline/agent_trigger_queue/*.queue.json)
# CURSOR_AGENT_QUEUE_ENABLED=1
# CURSOR_AGENT_QUEUE_MAX=50

# Feed: after reloading content on the Feed tab, spawn pipeline-generate for eligible pipelines scoped to the selected Instagram account (same rules as cron: template + backing; skips agent-busy + deep generating queues)
# FEED_REFRESH_GENERATE_ENABLED=1
# FEED_REFRESH_GENERATE_MAX=20
# FEED_REFRESH_GENERATE_MAX_QUEUE_PER_PIPELINE=   # default: PIPELINE_CRON_MAX_QUEUE_PER_PIPELINE or 2

# Embeddings: PHP `embed_text` + generation alignment prefer Google AI Gemini when GEMINI_API_KEY is set (REST = same API as `google.genai` SDK).
# GEMINI_API_KEY=                    # AI Studio / Google AI API key (also GOOGLE_GENAI_API_KEY)
# GEMINI_EMBED_MODEL=gemini-embedding-2-preview
# GEMINI_EMBED_OUTPUT_DIMENSIONALITY=   # optional; truncate embedding length (newer models only)
# GEMINI_EMBED_MEDIA_MAX_BYTES=26214400 # max download size for alignment (image/video/audio URLs)
# OPENROUTER_API_KEY=
# Pipeline run: PHP writes pipelines/<subdir>/pipeline_input.json (reference image URLs + OpenRouter JSON for variation). Go should read this file.
# PIPELINE_INPUT_JSON_ENABLED=1
# PIPELINE_INPUT_LLM_MODEL=openai/gpt-4o-mini
# PIPELINE_INPUT_LLM_TEMPERATURE=0.88
# PIPELINE_INPUT_LLM_MAX_TOKENS=1400
# Pipeline Cursor agent — multimodal essence (OpenRouter → Gemini) on fetched backing media before the agent runs
# PIPELINE_AGENT_ESSENCE_ENABLED=1
# PIPELINE_AGENT_ESSENCE_MODEL=google/gemini-3-flash-preview
# PIPELINE_AGENT_ESSENCE_MAX_MEDIA_PARTS=10
# PIPELINE_AGENT_ESSENCE_VIDEO_MAX_BYTES=20971520
# PIPELINE_AGENT_ESSENCE_IMAGE_MAX_BYTES=12582912
# PIPELINE_AGENT_ESSENCE_TIMEOUT_SEC=240
# PIPELINE_AGENT_ESSENCE_MAX_TOKENS=4096
# PIPELINE_AGENT_ESSENCE_TEMPERATURE=0.35
# EMBED_MODEL=google/gemini-embedding-001
# OPENROUTER_VL_EMBED_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free   # image+text embeddings on OpenRouter when google/gemini-embedding-001 rejects image_url (provider routing)
# GENERATION_ALIGNMENT_ENABLED=1   # After approve/reject or sweep: store metadata.input_alignment (cosine distance vs backing reference; improving_vs_previous_generation vs last same-pipeline row)
# OPENAI_API_KEY=
# EMBED_URL=http://localhost:11434  # Ollama /api/embed (nomic-embed-text)

# Cursor Agent CLI — https://cursor.com/cli — https://cursor.com/blog/2-0 (Composer 2)
# The CLI is a directory: launcher + index.js + node_modules + native addons. Copying only `agent` breaks with:
#   Error: Cannot find module '/usr/local/bin/index.js'
# Fix: on the server run the official installer (curl -fsSL https://cursor.com/install | bash), or rsync the FULL install dir from a machine where `agent` works:
#   dirname "$(readlink -f "$(command -v agent)")"   # must contain index.js
# The `agent` entrypoint is often a script that runs Node. If Node is missing you get:
#   /usr/local/bin/agent: line N: /usr/local/bin/node: No such file or directory
# Fix: sudo apt install -y nodejs (or NodeSource LTS); then sudo ln -sf "$(command -v node)" /usr/local/bin/node if the script expects that path
# php-fpm user (www-data) often has HOME=/var/www, which is root-owned → agent cannot mkdir ~/.cursor or store login tokens.
# Create a writable home and point Cursor at it:
#   sudo install -d -o www-data -g www-data /var/lib/formatforge-cursor
#   sudo -u www-data env HOME=/var/lib/formatforge-cursor XDG_CONFIG_HOME=/var/lib/formatforge-cursor/.config \
#     XDG_DATA_HOME=/var/lib/formatforge-cursor/.local/share XDG_STATE_HOME=/var/lib/formatforge-cursor/.local/state \
#     XDG_CACHE_HOME=/var/lib/formatforge-cursor/.cache /usr/local/bin/agent login
# CURSOR_AGENT_HOME=/var/lib/formatforge-cursor   # FormatForge sets HOME+XDG_* for spawned agent / cursor-agent-run
# Put `agent` in e.g. /usr/local/bin (or set CURSOR_AGENT_BIN to a path www-data can execute)
# CURSOR_API_KEY=   # optional alternative to login (CI / non-interactive)
# CURSOR_AGENT_BIN=/usr/local/bin/agent   # REQUIRED for most VPS: full path (sudo resets PATH; home dirs may be inaccessible to www-data)
# CURSOR_AGENT_MODEL=google/nano-banana-pro   # default when unset; image-capable — pipeline prompts tell the agent it may edit images in-session
# CURSOR_AGENT_MODEL=composer-2               # optional: Cursor Composer 2
# Transcript-style log: stream-json writes NDJSON (assistant segments + tool calls) to .cursor-pipeline/cursor-agent.log. text = final reply only.
# Cursor CLI suppresses "thinking" / hidden reasoning in print mode for every format — see https://cursor.com/docs/cli/reference/output-format
# CURSOR_AGENT_OUTPUT_FORMAT=stream-json
# Optional with stream-json only: character-level assistant deltas (very verbose).
# CURSOR_AGENT_STREAM_PARTIAL_OUTPUT=0
# Use composer-2-fast for the faster variant (lower latency; different pricing).
# CURSOR_AGENT_ENABLED=1   # set 0 to skip auto-spawn (files + prompt still written)
#
# Optional: run cursor-agent-run as deploy user (e.g. FPM cannot write pipelines/, or agent/go PATH is for jhs only).
# Pipeline agent must still only edit pipelines/<subdir>/ — not index.php (see DEPLOYMENT.md).
# 1) sudo ./scripts/install-formatforge-cursor-agent-sudo.sh
# 2) sudo cp scripts/formatforge-cursor-agent.sudoers /etc/sudoers.d/formatforge-cursor-agent && sudo chmod 440 … && sudo visudo -cf …
# 3) Add jhs to the FPM group and share .cursor-pipeline (see script output); run agent login as jhs with CURSOR_AGENT_HOME
# CURSOR_AGENT_SUDO_USER=jhs
# CURSOR_AGENT_RUN_WRAPPER=/usr/local/sbin/formatforge-cursor-agent-run
#
# Browser TTY to run `agent` interactively — NOT served by PHP; use ttyd + nginx (see DEPLOYMENT.md § Agent web terminal).
# When set, Curate → Pipelines shows “Open browser terminal” for internal IPs by default.
# AGENT_WEB_TTY_URL=https://ttyd.your-internal-host.example/
# AGENT_WEB_TTY_INTERNAL_ONLY=1   # 0 = show link to everyone who can log in (only if ttyd is already auth-protected)
