# PocketBase — PHP reaches this URL (overrides .pb-port when set)
POCKETBASE_URL=http://127.0.0.1:8090
# Browser / nginx: defaults to APP_URL; for PHP built-in server without proxy: POCKETBASE_PUBLIC_URL=http://127.0.0.1:8090
# POCKETBASE_PUBLIC_URL=

APP_PORT=8000
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Optional: ?migrate=SECRET PocketBase migration hint endpoint
MIGRATE_SECRET=

# Garage S3 (optional — not used by minimal index.php)
GARAGE_ENDPOINT=http://127.0.0.1:3900
# GARAGE_PUBLIC_URL=
# GARAGE_PUBLIC_ROOT_DOMAIN=
# GARAGE_PUBLIC_SCHEME=https
GARAGE_ACCESS_KEY=
GARAGE_SECRET_KEY=
GARAGE_BUCKET=formatforge
GARAGE_REGION=garage

# Replicate / fal (optional)
REPLICATE_API_TOKEN=
# FAL_KEY=

# OpenRouter — after each Fetch upload, vision pass stores image_recreation_prompt on input_media.metadata (optional)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-3.1-pro-preview

# Google Gemini — embeddings for prompts collection on Fetch (separate from OpenRouter vision)
# GEMINI_API_KEY=
# GEMINI_EMBED_MODEL=gemini-embedding-2-preview

# Instagram / Facebook Login (Connect Instagram in the web UI)
FB_APP_ID=
FB_APP_SECRET=
INSTAGRAM_REDIRECT_URI=
META_WEBHOOK_VERIFY_TOKEN=

# gallery-dl / yt-dlp — “Save from URL” in the web UI (optional absolute paths if not on PATH)
# GALLERY_DL_PATH=gallery-dl
# YT_DLP_PATH=yt-dlp
# Optional Netscape cookies override (defaults: storage/cookies/instagram_cookies.txt or cookies.txt)
# GALLERY_DL_COOKIES=
# YT_DLP_COOKIES=

# Fetch UI uploads to this PocketBase collection (must have a File field named fetched_files; see pb_migrations/1774700000_input_media_fetched_files.js)
# INPUT_MEDIA_COLLECTION=input_media
# Prompt rows (prompt_text, prompt_embedding, relations) when GEMINI_API_KEY is set after successful Fetch vision pass
# PROMPTS_COLLECTION=prompts

# App
APP_URL=http://localhost
APP_VERSION=v1.1.230
SITE_NAME=FormatForge
# Signed-in users: GET ?ff_debug_json=1 returns safe JSON diagnostics (same as Debug console in the UI).
