# PocketBase (PHP must reach this URL — same host: 127.0.0.1:8090)
POCKETBASE_URL=http://127.0.0.1:8090
# Frontend fetches from this URL. Default: site_url (nginx proxies /api/ and /_/ to PocketBase). For start.sh without nginx: POCKETBASE_PUBLIC_URL=http://127.0.0.1:8090
# POCKETBASE_PUBLIC_URL=
APP_PORT=8000
ADMIN_EMAIL=
ADMIN_PASSWORD=
MIGRATE_SECRET=

# Garage S3
GARAGE_ENDPOINT=http://127.0.0.1:3900
GARAGE_ACCESS_KEY=
GARAGE_SECRET_KEY=
GARAGE_BUCKET=formatforge
GARAGE_REGION=garage

# Replicate
REPLICATE_API_TOKEN=

# fal.ai (alternative to Replicate for video generation)
# FAL_KEY=
# VIDEO_PROVIDER=replicate|fal  # default: replicate if token set, else fal if FAL_KEY set
# FAL_VIDEO_MODEL=fal-ai/kling-video/v2.5-turbo/pro/text-to-video

# Instagram / Facebook App (requires business_management permission in App Dashboard)
FB_APP_ID=
FB_APP_SECRET=
INSTAGRAM_REDIRECT_URI=   # e.g. https://formatforgeplus.com/instagram/callback
META_WEBHOOK_VERIFY_TOKEN=   # For webhooks: same value as "Verify Token" in Meta App Dashboard

# Antfly (self-hosted) — URL must be the Termite store API (batch writes), not only the dashboard
ANTFLY_URL=http://127.0.0.1:8080
ANTFLY_API_KEY=

# Source link fetchers (Curate → Fetch) — install gallery-dl + yt-dlp on the host (pip); set paths if not on PATH
# GALLERY_DL_PATH=gallery-dl
# YT_DLP_PATH=yt-dlp
# e.g. GALLERY_DL_PATH=/home/you/.local/bin/gallery-dl
# Instagram needs Netscape cookies.txt — see storage/cookies/README.md
# If unset, uses storage/cookies/instagram_cookies.txt or storage/cookies/cookies.txt (first match).
# GALLERY_DL_COOKIES=/var/www/html/storage/cookies/cookies.txt
# YT_DLP_COOKIES=   # optional; defaults to same file as gallery cookies

# App
APP_URL=http://localhost
# Production: APP_URL=https://formatforgeplus.com
APP_VERSION=v1.0.76
WINNING_TEMPLATE_VIEW_SHARE_RATIO=0.05
FFMPEG_PATH=/usr/bin/ffmpeg

# Allow signup on login page (set to 1 to always show create-account form)
# When unset, signup is only shown when request is from internal IP (100.x, 10.x, 192.168.x, 172.16-31.x)
# ALLOW_SIGNUP=1

# Autonomous pipeline triggers — PHP spawns Cursor (web POST: Curate → Fetch, or Reject)
# When content is novel on fetch or reject streak hits, a trigger is written under .cursor-pipeline/triggers/, pipeline dir + prompt are prepared, then exec+nohup runs cursor-agent-run
# CURSOR_PIPELINE_TRIGGER_DIR=/path/to/custom/triggers   # default: .cursor-pipeline/triggers (legacy: PI_TRIGGER_DIR)
# NOVEL_DISTANCE_THRESHOLD=0.35  # Antfly semantic distance: above this vs pipeline_refs = novel (create pipeline). Embeddings run in Antfly, not PHP.
# TARGET_POSTS_PER_DAY=60        # Included in Cursor agent JSON (operating_context) vs published_count_last_24h; set 0 to omit cadence fields
# PIPELINE_REJECT_STREAK=3       # Consecutive rejects for same metadata.pipeline_id → Cursor edits that pipeline

# Embeddings: PHP novelty checks (embed_text) AND Antfly semantic_idx (Termite → OpenRouter on ingest)
# OPENROUTER_API_KEY=
# EMBED_MODEL=google/gemini-embedding-001
# OPENAI_API_KEY=
# EMBED_URL=http://localhost:11434  # Ollama /api/embed (nomic-embed-text)

# Cursor Agent CLI — https://cursor.com/cli — https://cursor.com/blog/2-0 (Composer 2)
# The CLI is a directory: launcher + index.js + node_modules + native addons. Copying only `agent` breaks with:
#   Error: Cannot find module '/usr/local/bin/index.js'
# Fix: on the server run the official installer (curl -fsSL https://cursor.com/install | bash), or rsync the FULL install dir from a machine where `agent` works:
#   dirname "$(readlink -f "$(command -v agent)")"   # must contain index.js
# The `agent` entrypoint is often a script that runs Node. If Node is missing you get:
#   /usr/local/bin/agent: line N: /usr/local/bin/node: No such file or directory
# Fix: sudo apt install -y nodejs (or NodeSource LTS); then sudo ln -sf "$(command -v node)" /usr/local/bin/node if the script expects that path
# php-fpm user (www-data) often has HOME=/var/www, which is root-owned → agent cannot mkdir ~/.cursor or store login tokens.
# Create a writable home and point Cursor at it:
#   sudo install -d -o www-data -g www-data /var/lib/formatforge-cursor
#   sudo -u www-data env HOME=/var/lib/formatforge-cursor XDG_CONFIG_HOME=/var/lib/formatforge-cursor/.config \
#     XDG_DATA_HOME=/var/lib/formatforge-cursor/.local/share XDG_STATE_HOME=/var/lib/formatforge-cursor/.local/state \
#     XDG_CACHE_HOME=/var/lib/formatforge-cursor/.cache /usr/local/bin/agent login
# CURSOR_AGENT_HOME=/var/lib/formatforge-cursor   # FormatForge sets HOME+XDG_* for spawned agent / cursor-agent-run
# Put `agent` in e.g. /usr/local/bin (or set CURSOR_AGENT_BIN to a path www-data can execute)
# CURSOR_API_KEY=   # optional alternative to login (CI / non-interactive)
# CURSOR_AGENT_BIN=/usr/local/bin/agent   # REQUIRED for most VPS: full path (sudo resets PATH; home dirs may be inaccessible to www-data)
# CURSOR_AGENT_MODEL=composer-2-fast
# CURSOR_AGENT_ENABLED=1   # set 0 to skip auto-spawn (files + prompt still written)
