# PocketBase — PHP reaches this URL (overrides .pb-port when set)
POCKETBASE_URL=http://127.0.0.1:8090
# Browser-visible PocketBase URL (file links, redirects). Defaults to APP_URL.
# Production (nginx/formatforgeplus.conf): PB is proxied at /api/ on the same host — use the site origin:
#   POCKETBASE_PUBLIC_URL=https://formatforgeplus.com
# Local PHP built-in without proxy:
# POCKETBASE_PUBLIC_URL=http://127.0.0.1:8090
# POCKETBASE_PUBLIC_URL=

APP_PORT=8000
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Optional: ?migrate=SECRET PocketBase migration hint endpoint
MIGRATE_SECRET=

# Garage S3 (optional). One bucket for the app; keys are scoped per PocketBase social_accounts id:
#   social_accounts/{record_id}/your-file.ext
#   social_accounts/{record_id}/ai/slides|images/… — AI outputs when that account is selected in Media (same bucket)
# Create the bucket: scripts/garage-ensure-social-content-bucket.sh (needs aws CLI + keys below).
GARAGE_ENDPOINT=http://127.0.0.1:3900
# Public web base for GARAGE_SOCIAL_CONTENT_BUCKET (Instagram must fetch images without cookies). Example:
#   GARAGE_PUBLIC_URL=https://my-bucket.web.100.107.100.17.sslip.io
# Or: GARAGE_PUBLIC_ROOT_DOMAIN=100.107.100.17.sslip.io  (builds {bucket}.web.{domain})
# GARAGE_PUBLIC_URL=
# GARAGE_PUBLIC_ROOT_DOMAIN=
# GARAGE_PUBLIC_SCHEME=https
GARAGE_ACCESS_KEY=
GARAGE_SECRET_KEY=
# Legacy / generic bucket name (used as fallback if GARAGE_SOCIAL_CONTENT_BUCKET is unset)
GARAGE_BUCKET=formatforge
# Preferred bucket for social-account-scoped objects (default formatforge-social when both bucket vars are empty).
# Use your generic bucket name here (e.g. my-bucket); Instagram handles like @fresh.divs are NOT separate buckets — keys are under social_accounts/{pocketbase_social_accounts_id}/…
GARAGE_SOCIAL_CONTENT_BUCKET=formatforge-social
GARAGE_REGION=garage
# When Garage is configured: save OpenRouter slide JSON and Replicate images under generated/users/{pb_user_id}/… in GARAGE_SOCIAL_CONTENT_BUCKET. Set 0 to keep only ephemeral provider URLs.
# FF_SAVE_GENERATED_TO_GARAGE=1

# Replicate — AI tab image generation (google/nano-banana-pro). Optional defaults:
REPLICATE_API_TOKEN=
# REPLICATE_NANO_RESOLUTION=2K
# REPLICATE_NANO_OUTPUT_FORMAT=png
# FAL_KEY=

# OpenRouter — required for “Generate slides” (JSON only; Gemini/OpenAI are not used for slides)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional, sent as Referer (OpenRouter rankings)
# OPENROUTER_HTTP_REFERER=https://127.0.0.1

# Google Gemini — embeddings API (?action=embed_text | embed_image | prompt_embed) only; not used for slide text
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_EMBED_MODEL=gemini-embedding-2-preview

# OpenAI — not used for slide text in this app
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Instagram / Facebook Login (Connect Instagram in the web UI)
FB_APP_ID=
FB_APP_SECRET=
# Production (same host as APP_URL): INSTAGRAM_REDIRECT_URI=https://formatforgeplus.com/instagram/callback
INSTAGRAM_REDIRECT_URI=
META_WEBHOOK_VERIFY_TOKEN=
# Optional override for the Meta OAuth scope string (comma-separated). If unset, a default Instagram Graph scope is used.
# INSTAGRAM_OAUTH_SCOPE=
# Scheduled Instagram carousels: cron must GET ?action=process_instagram_schedules&cron_secret=YOUR_CRON_SECRET (same-origin or curl).
# CRON_SECRET=          # Also used to sign public ?action=ig_public_image URLs (Instagram fetches images without cookies).
# IG_PUBLIC_IMAGE_SECRET=   # Optional; overrides CRON_SECRET for image signing only.
# FF_CRON_PB_TOKEN=   # PocketBase token: cron jobs + ig_public_image must read input_media files (superuser or equivalent).
# Instagram scheduling (default): each still slide is rendered to a 1080×1350 JPEG via Playwright (video-pipeline/render-ig-jpegs.mjs).
# Chromium must live where php-fpm can read it (not only in deploy-user ~/.cache). Recommended:
#   cd video-pipeline && npm ci && PLAYWRIGHT_BROWSERS_PATH="$(pwd)/.playwright-browsers" npx playwright install chromium && chmod -R a+rX .playwright-browsers
# If video-pipeline/.playwright-browsers exists, the app uses it automatically (override with FF_PLAYWRIGHT_BROWSERS_PATH).
# FF_NODE_BIN=/usr/bin/node
# FF_PLAYWRIGHT_BROWSERS_PATH=/var/www/formatforge/video-pipeline/.playwright-browsers
# FF_IG_USE_SLIDE_RENDER=0       # Optional: legacy schedule using only raw content/background image URLs (no full-frame JPEG per slide)
# Install php-gd (e.g. php8.3-gd): Instagram feed API expects JPEG; PNG/WebP/GIF are re-encoded when publishing.

# gallery-dl / yt-dlp — “Save from URL” in the web UI (optional absolute paths if not on PATH)
# GALLERY_DL_PATH=gallery-dl
# YT_DLP_PATH=yt-dlp
# Optional Netscape cookies override (defaults: storage/cookies/instagram_cookies.txt or cookies.txt)
# GALLERY_DL_COOKIES=
# YT_DLP_COOKIES=

# PocketBase collection ids (embeddings API ?action=prompt_embed links prompts → input_media.metadata)
# INPUT_MEDIA_COLLECTION=input_media
# OUTPUT_MEDIA_COLLECTION=output_media
# PROMPTS_COLLECTION=prompts
# PocketBase auth-with-password collection (usually users)
# USERS_COLLECTION=users

# Access gate: only these PocketBase user emails may use the app (comma-separated, case-insensitive). If unset, defaults to jnstrdm05@gmail.com,dan@bbxp.app
# FF_ALLOWED_EMAILS=jnstrdm05@gmail.com,dan@bbxp.app

# App — public site URL (no trailing slash). Used for OAuth redirects, Instagram image URL resolution, etc.
# Production: APP_URL=https://formatforgeplus.com
APP_URL=http://localhost
APP_VERSION=v1.1.295
# Post now under Cloudflare Tunnel: defaults to background publish (fastcgi_finish_request) so the tunnel gets HTTP body before Playwright/Meta.
# Set to 0 to force one long synchronous response (may 502 behind tunnel if origin is silent too long).
# Opt-in only: return HTTP early after queueing, then publish in same PHP worker (can leave rows stuck "scheduled"
# if FPM/nginx cuts the worker after the response). Default is synchronous publish for Post now.
# FF_IG_POST_NOW_BACKGROUND=1
# Recommended: sudo apt install php8.3-mbstring (FormatForge uses it when present; falls back to UTF-8-safe helpers).
#
# 502 on “Post now” / cron — read this if failure hits in ~5s (not 100s):
# This host often uses **Cloudflare Tunnel** (cloudflared → http://localhost:80), not only “orange cloud to public IP”.
# Path: Browser → Cloudflare edge → tunnel (QUIC) → nginx → PHP. If PHP sends no bytes for a while, logs show
# `journalctl -u cloudflared`: "Incoming request ended abruptly: context canceled" and the browser gets a fast 502 HTML page.
# Diagnose: `sudo journalctl -u cloudflared -f` during POST; `/var/log/nginx/error.log` for PHP fatals. Bypass tunnel by
# opening the app via Tailscale/MagicDNS or another direct URL to nginx if you have one.
# (1) Public DNS “proxied” (orange cloud) is a separate hop; CF ~100s cap applies there too. The app is not “hosted on Cloudflare”.
# (2) PHP-FPM often has max_execution_time=30; Instagram + Playwright need minutes. ini_set alone can be IGNORED if the pool
# sets php_admin_value[max_execution_time]. Add under [www] in /etc/php/8.3/fpm/pool.d/www.conf:
#   php_admin_value[max_execution_time] = 300
# then sudo systemctl reload php8.3-fpm. Watch /var/log/nginx/error.log for “FormatForge: max_execution_time is …”.
SITE_NAME=FormatForge
# Signed-in allowlisted users: GET ?ff_debug_json=1 returns safe JSON diagnostics.
# If ?action=media_library returns 500, set FF_DEBUG_MEDIA=1 to include the PHP exception message in the JSON (operators only).
# FF_DEBUG_MEDIA=1
