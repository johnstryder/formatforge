# Copied from project .env by setup-pipeline
# Pipeline-specific overrides. Cursor / pipeline author chooses replicate or fal per pipeline.
REPLICATE_API_TOKEN=
# FAL_KEY=
# VIDEO_PROVIDER=replicate|fal
# FAL_VIDEO_MODEL=fal-ai/kling-video/v2.5-turbo/pro/text-to-video
# Optional pipeline rendering strategy hint for agent-authored code paths:
# RENDER_STRATEGY=htmlcss|canvas2d|svg|composite
POCKETBASE_URL=http://127.0.0.1:8090
GARAGE_ENDPOINT=http://127.0.0.1:3900
# GARAGE_PUBLIC_URL=   # optional; same as app .env when pipeline uploads public URLs
GARAGE_ACCESS_KEY=
GARAGE_SECRET_KEY=
GARAGE_BUCKET=formatforge
GARAGE_REGION=garage
FORMATFORGE_EMAIL=
FORMATFORGE_PASSWORD=
PROMPT=A cinematic shot of a person walking through a modern city at sunset
# PROMPT_TEMPLATE=A cinematic shot inspired by {{.SourceURL}}
