# Copy to e.g. /etc/systemd/system/formatforge-cursor-agent-sync.timer
#
# sudo cp scripts/cursor-agent-sync.timer.example /etc/systemd/system/formatforge-cursor-agent-sync.timer
# sudo systemctl daemon-reload
# sudo systemctl enable --now formatforge-cursor-agent-sync.timer
# sudo systemctl list-timers formatforge-cursor-agent-sync.timer

[Unit]
Description=Periodic Cursor Agent CLI sync to /opt/cursor-agent

[Timer]
OnCalendar=daily
RandomizedDelaySec=1h
Persistent=true
Unit=formatforge-cursor-agent-sync.service

[Install]
WantedBy=timers.target
