#!/usr/bin/env bash
# Use this so /etc/cron.d needs ONE short line (wrapped long lines break cron).
#
#   sudo cp scripts/cursor-agent-sync-root-invoke.sh.example /usr/local/sbin/formatforge-cursor-agent-sync
#   sudo nano /usr/local/sbin/formatforge-cursor-agent-sync   # fix exports + exec path
#   sudo chmod 755 /usr/local/sbin/formatforge-cursor-agent-sync
#
set -euo pipefail
export CURSOR_AGENT_SOURCE_USER=jhs
export CURSOR_AGENT_OPT_DIR=/opt/cursor-agent
export CURSOR_AGENT_SYNC_RELOAD_PHP=1
# Log both cron and manual `sudo …formatforge-cursor-agent-sync` (cron redirection alone only logs scheduled runs).
LOG=/var/log/formatforge-cursor-agent-sync.log
exec /var/www/formatforge/scripts/sync-cursor-agent-to-opt.sh >>"$LOG" 2>&1
