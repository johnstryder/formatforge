# Copy to /etc/default/formatforge-cursor-agent (root:root, chmod 644).
# Used by /usr/local/sbin/formatforge-cursor-agent-run (sudo from www-data → deploy user).

# Absolute path to FormatForge clone (directory containing index.php).
FORMATFORGE_ROOT=/home/jhs/formatforge

# PHP CLI binary (must match production; use same as PHP_CLI_BINARY in app .env if set).
PHP_CLI=/usr/bin/php

# Optional: export Cursor-related vars for the agent process (jhs’s login shell does not run here).
# Prefer `agent login` as jhs with HOME under a writable directory, then:
# CURSOR_AGENT_HOME=/var/lib/formatforge-cursor-jhs
# export CURSOR_AGENT_HOME HOME="$CURSOR_AGENT_HOME" XDG_CONFIG_HOME="$CURSOR_AGENT_HOME/.config" \
#   XDG_DATA_HOME="$CURSOR_AGENT_HOME/.local/share" XDG_STATE_HOME="$CURSOR_AGENT_HOME/.local/state" \
#   XDG_CACHE_HOME="$CURSOR_AGENT_HOME/.cache"
